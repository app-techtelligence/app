# Copy to .dev.vars (gitignored) for local development.
# Production values are set with `wrangler secret put <NAME>`.

# Resend API key — https://resend.com/api-keys. Leave empty to stub email sending locally.
RESEND_API_KEY=

# Cloudflare Turnstile secret. This is the official "always passes" TEST key:
# https://developers.cloudflare.com/turnstile/troubleshooting/testing/
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
