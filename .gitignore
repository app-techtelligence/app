# dependencies
node_modules/

# builds
.next/
.open-next/
out/
dist/

# tooling caches
.turbo/
.wrangler/
*.tsbuildinfo

# generated at prebuild from lib/security-headers.mjs
apps/web/public/_headers

# secrets & env — never commit
.dev.vars
.env
.env.*
!.env.example
!.env.local.example
!.dev.vars.example

# raw course media — lives in object storage (R2), never in git
# (anchored to repo root so it doesn't catch components/sections/course/)
/course/

# generated blog covers — uploaded to R2 via the admin editor, never in git
# (regenerate with apps/web/scripts/generate-blog-covers.mjs)
/blog-covers/

# logs & OS noise
*.log
.DS_Store
Thumbs.db

# Claude Code personal settings
.claude/settings.local.json
